{
  "rules": {
    "games": {
      ".read": true,
      ".write": "auth != null"
    },
    "results": {
      ".read": true,
      ".write": "auth != null"
    },
    "carouselPhotos": {
      ".read": true,
      ".write": "auth != null"
    },
    "opponents": {
      ".read": true,
      ".write": "auth != null"
    },
    "news": {
      ".read": true,
      ".write": "auth != null"
    },
    "siteMeta": {
      ".read": true,
      ".write": "auth != null"
    },
    "trainers": {
      ".read": true,
      ".write": "auth != null"
    },
    "trainerAvailability": {
      ".read": true,
      ".write": "auth != null"
    },
    "appointmentClaims": {
      ".read": true,
      "$trainerId": {
        "$date": {
          "$slotId": {
            ".write": "auth != null || !data.exists()",
            ".validate": "auth != null || newData.hasChildren(['appointmentId','slotId','time','timeValue','endTime','endTimeValue','durationMinutes','price','status','createdAt']) && newData.child('status').val() === 'pending'"
          }
        }
      }
    },
    "appointmentRequests": {
      ".read": "auth != null",
      "$requestId": {
        ".write": "auth != null || !data.exists()",
        ".validate": "auth != null || newData.hasChildren(['trainerId','date','slotId','time','endTime','durationMinutes','price','location','fullName','phone','email','status','createdAt','updatedAt']) && newData.child('status').val() === 'pending'"
      }
    }
  }
}
